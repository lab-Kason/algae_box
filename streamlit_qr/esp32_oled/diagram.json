{
  "version": 1,
  "author": "Algae Box",
  "editor": "wokwi",
  "parts": [
    {
      "type": "board-esp32-devkit-c-v4",
      "id": "esp",
      "top": 0,
      "left": 100,
      "attrs": {}
    },
    {
      "type": "wokwi-ssd1306",
      "id": "oled1",
      "top": -120,
      "left": 80,
      "attrs": { "i2cAddress": "0x3c" }
    },
    {
      "type": "wokwi-ds18b20",
      "id": "temp1",
      "top": 180,
      "left": -50,
      "attrs": { "temperature": "25" }
    },
    {
      "type": "wokwi-potentiometer",
      "id": "pot1",
      "top": 200,
      "left": 100,
      "attrs": { "label": "TDS/EC" }
    },
    {
      "type": "wokwi-pushbutton",
      "id": "btn1",
      "top": 200,
      "left": 220,
      "attrs": { "label": "Harvest", "color": "green" }
    }
  ],
  "connections": [
    ["esp:TX", "$serialMonitor:RX", ""],
    ["esp:RX", "$serialMonitor:TX", ""],
    ["oled1:GND", "esp:GND.1", "black", ["v20", "h10"]],
    ["oled1:VCC", "esp:3V3", "red", ["v30", "h20"]],
    ["oled1:SCL", "esp:22", "green", ["v40", "h30"]],
    ["oled1:SDA", "esp:21", "blue", ["v50", "h40"]],
    ["temp1:VCC", "esp:3V3", "red", ["v-30"]],
    ["temp1:GND", "esp:GND.2", "black", ["v-20"]],
    ["temp1:DQ", "esp:4", "yellow", ["v-10"]],
    ["pot1:VCC", "esp:3V3", "red", ["v-50"]],
    ["pot1:GND", "esp:GND.2", "black", ["v-40"]],
    ["pot1:SIG", "esp:34", "orange", ["v-30"]],
    ["btn1:1.l", "esp:GND.2", "black", ["v10"]],
    ["btn1:2.l", "esp:15", "purple", ["v20"]]
  ],
  "serialMonitor": {
    "display": "always",
    "newline": "lf"
  }
}
